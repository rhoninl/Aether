{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorldManifest",
  "description": "The canonical WorldManifest.\n\nStructural invariants enforced by [`WorldManifest::validate`]: - `schema_version` equals [`crate::CURRENT_SCHEMA_VERSION`]. - `world_id` is non-empty. - Chunk coords are unique per LOD. - Entity ids are unique. - Prop ids are unique. - Spawn point ids are unique. - Script ids are unique. - At most one spawn point has `is_default == true`.",
  "type": "object",
  "required": [
    "schema_version",
    "world_id"
  ],
  "properties": {
    "chunks": {
      "description": "Streaming chunks.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/ChunkManifest"
      }
    },
    "display_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "entities": {
      "description": "Declarative entities spawned at world boot.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/Entity"
      }
    },
    "lighting": {
      "description": "Lighting + skybox settings.",
      "default": {
        "ambient_intensity": 0.10000000149011612,
        "sun_intensity": 1.0
      },
      "allOf": [
        {
          "$ref": "#/definitions/LightingSettings"
        }
      ]
    },
    "meta": {
      "description": "Authoring metadata — purely informational, never consumed by the runtime.",
      "default": {},
      "allOf": [
        {
          "$ref": "#/definitions/WorldManifestMeta"
        }
      ]
    },
    "migration_notes": {
      "description": "Migration breadcrumbs left by the `Migrator` chain. Readers should log and ideally surface these to authors.",
      "type": "object",
      "additionalProperties": true
    },
    "props": {
      "description": "Reusable prop templates.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/Prop"
      }
    },
    "runtime_settings": {
      "description": "Runtime settings (gravity, tick rate, etc.).",
      "default": {
        "gravity": -9.8100004196167,
        "max_players": 32,
        "tick_rate_hz": 60
      },
      "allOf": [
        {
          "$ref": "#/definitions/RuntimeSettings"
        }
      ]
    },
    "schema_version": {
      "$ref": "#/definitions/SchemaVersion"
    },
    "scripts": {
      "description": "Script references. Inline scripts are fine for small worlds; in production we expect these to be `source_cid`/`wasm_cid` references.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/ScriptArtifact"
      }
    },
    "spawn_points": {
      "description": "Spawn points.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/SpawnPoint"
      }
    },
    "world_id": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "CapabilityDeclaration": {
      "description": "Explicit capability declaration. The runtime enforces that the script only calls host functions in this bundle.\n\nThis list is deliberately conservative and small; new capabilities should be added via the versioning/migration policy.",
      "type": "object",
      "properties": {
        "custom": {
          "description": "Free-form custom capabilities — the runtime must recognize each string.",
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "network_broadcast": {
          "description": "Issue network messages to clients.",
          "default": false,
          "type": "boolean"
        },
        "persistence_read": {
          "description": "Access persistent storage (key/value on behalf of the world).",
          "default": false,
          "type": "boolean"
        },
        "persistence_write": {
          "default": false,
          "type": "boolean"
        },
        "read_world": {
          "description": "Read state from the world (queries, component reads).",
          "default": false,
          "type": "boolean"
        },
        "spawn_entities": {
          "description": "Spawn/despawn entities by prop id.",
          "default": false,
          "type": "boolean"
        },
        "write_world": {
          "description": "Mutate world state (spawn entities, set components).",
          "default": false,
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "ChunkCoord": {
      "description": "Integer grid coordinate identifying a chunk.\n\nA world is laid out on a 3-dimensional integer grid with configurable cell size (see [`ChunkManifest::cell_size_meters`]). Two chunks with the same `ChunkCoord` collide; the manifest must enforce uniqueness.",
      "type": "object",
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "type": "integer",
          "format": "int32"
        },
        "y": {
          "type": "integer",
          "format": "int32"
        },
        "z": {
          "type": "integer",
          "format": "int32"
        }
      },
      "additionalProperties": false
    },
    "ChunkKind": {
      "description": "Streaming classification. Mirrors `aether_world_runtime::ChunkKind`.",
      "type": "string",
      "enum": [
        "terrain",
        "prop_mesh",
        "lighting",
        "audio",
        "navigation"
      ]
    },
    "ChunkManifest": {
      "description": "Declarative chunk manifest. A world's chunk set is the list of these manifests. Each manifest points to a content-addressed asset blob via `asset_cid`.",
      "type": "object",
      "required": [
        "asset_cid",
        "coord",
        "kind",
        "size_bytes"
      ],
      "properties": {
        "asset_cid": {
          "description": "Content address of the backing asset blob (mesh, lightmap, etc.).",
          "type": "string"
        },
        "coord": {
          "$ref": "#/definitions/ChunkCoord"
        },
        "kind": {
          "description": "Semantic classification; controls which runtime pipeline consumes the chunk.",
          "allOf": [
            {
              "$ref": "#/definitions/ChunkKind"
            }
          ]
        },
        "lod": {
          "description": "LOD level represented by this manifest. Multiple manifests may share a `coord` if they differ in `lod`.",
          "default": 0,
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "prefetch_distance_meters": {
          "description": "Minimum world-space distance at which the chunk can be prefetched.",
          "default": 0.0,
          "type": "number",
          "format": "float"
        },
        "size_bytes": {
          "description": "Byte size of the backing asset (hint for streaming scheduler).",
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "tags": {
          "description": "Free-form tags for authoring and agent filtering.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "Component": {
      "description": "A declarative component attached to an entity.\n\nComponents are addressed by string `ty` (for example `\"physics.rigid_body\"` or `\"render.mesh\"`); the runtime dispatches to the registered component type. This decoupling is what lets the agent emit arbitrary components without the host Rust code needing to enumerate every possible type.",
      "type": "object",
      "required": [
        "ty",
        "value"
      ],
      "properties": {
        "ty": {
          "description": "Dotted-path type identifier.",
          "type": "string"
        },
        "value": {
          "description": "The structured value payload.",
          "allOf": [
            {
              "$ref": "#/definitions/ComponentValue"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "ComponentValue": {
      "description": "Declarative component value. Restricted to a small typed tree so that both humans and agents can author it without consulting the Rust type system.\n\nThe `Ref` variant links to another declared entity by `id`, making cross- entity references first-class (instead of smuggling them through strings).",
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "integer",
          "format": "int64"
        },
        {
          "type": "number",
          "format": "double"
        },
        {
          "type": "string"
        },
        {
          "description": "Entity reference by declarative `id`. Must come before `Map` so that serde's untagged deserializer matches the `$ref` shape first.",
          "type": "object",
          "required": [
            "$ref"
          ],
          "properties": {
            "$ref": {
              "type": "string"
            }
          }
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ComponentValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/ComponentValue"
          }
        }
      ]
    },
    "Entity": {
      "description": "Declarative entity. Mirrors `aether_ecs::Entity` but is keyed by a stable string ID rather than the runtime generational index.\n\nThe runtime resolves `id` to a generational `aether_ecs::Entity` at load time; the declarative form is insulated from ID recycling.",
      "type": "object",
      "required": [
        "id",
        "kind",
        "transform"
      ],
      "properties": {
        "components": {
          "description": "Components attached to this entity at spawn time.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/Component"
          }
        },
        "id": {
          "description": "Stable, human- and agent-readable identifier. Must be unique within a world manifest.",
          "type": "string"
        },
        "kind": {
          "description": "Semantic role of this entity. Hints the runtime at archetype placement.",
          "allOf": [
            {
              "$ref": "#/definitions/EntityKind"
            }
          ]
        },
        "parent": {
          "description": "Optional parent entity `id`. If set, this entity is spawned as a child in the scene graph.",
          "type": [
            "string",
            "null"
          ]
        },
        "tags": {
          "description": "Free-form tags for agent filtering (e.g., \"boss\", \"merchant\").",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transform": {
          "description": "World transform at spawn time.",
          "allOf": [
            {
              "$ref": "#/definitions/Transform"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "EntityKind": {
      "description": "Common entity shapes. Extra kinds are expected to be added later; readers must therefore treat `Custom` as an extension hatch.",
      "oneOf": [
        {
          "description": "A static or kinematic prop (mesh, collider, etc.).",
          "type": "string",
          "enum": [
            "prop"
          ]
        },
        {
          "description": "A player or agent-controllable character.",
          "type": "string",
          "enum": [
            "character"
          ]
        },
        {
          "description": "An interactable NPC.",
          "type": "string",
          "enum": [
            "npc"
          ]
        },
        {
          "description": "A non-visible gameplay trigger (volume).",
          "type": "string",
          "enum": [
            "trigger"
          ]
        },
        {
          "description": "Anything else; resolvable by user-space systems.",
          "type": "object",
          "required": [
            "custom"
          ],
          "properties": {
            "custom": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "LightingSettings": {
      "description": "Lighting + skybox.",
      "type": "object",
      "properties": {
        "ambient_intensity": {
          "default": 0.10000000149011612,
          "type": "number",
          "format": "float"
        },
        "skybox_asset_cid": {
          "description": "Optional skybox asset CID.",
          "type": [
            "string",
            "null"
          ]
        },
        "sun_intensity": {
          "default": 1.0,
          "type": "number",
          "format": "float"
        }
      },
      "additionalProperties": false
    },
    "Prop": {
      "description": "A declarative prop definition — a reusable spawnable template.\n\nAn [`Entity`] carries runtime state (position, transform); a [`Prop`] declares the *template* from which many entities may be spawned.",
      "type": "object",
      "required": [
        "asset_cid",
        "id"
      ],
      "properties": {
        "asset_cid": {
          "description": "Asset CID (content-addressed mesh/animation/etc.).",
          "type": "string"
        },
        "default_components": {
          "description": "Default components applied when spawning.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/Component"
          }
        },
        "default_transform": {
          "description": "Default transform used when a spawn point doesn't override it.",
          "default": {
            "position": [
              0.0,
              0.0,
              0.0
            ],
            "rotation_euler_deg": [
              0.0,
              0.0,
              0.0
            ],
            "scale": [
              1.0,
              1.0,
              1.0
            ]
          },
          "allOf": [
            {
              "$ref": "#/definitions/Transform"
            }
          ]
        },
        "id": {
          "type": "string"
        },
        "tags": {
          "description": "Free-form tags for agent filtering.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "RuntimeSettings": {
      "description": "Runtime settings.",
      "type": "object",
      "properties": {
        "gravity": {
          "description": "Gravity in m/s^2. Must be in `[-100, 100]`.",
          "default": -9.8100004196167,
          "type": "number",
          "format": "float"
        },
        "max_players": {
          "description": "Maximum concurrent players in this world shard.",
          "default": 32,
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "tick_rate_hz": {
          "description": "Simulation tick rate. Must be in `(0, 240]`.",
          "default": 60,
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "SchemaVersion": {
      "description": "Canonical wire schema version. Currently 1 is the stable release; 0 is accepted for migration only.",
      "type": "integer",
      "enum": [
        0,
        1
      ]
    },
    "ScriptArtifact": {
      "description": "Top-level script artifact.\n\nScripts are referenced from [`crate::world_manifest::WorldManifest::scripts`] by stable `id`. Runtime resolves the id to this artifact, verifies the signature, confirms the capability bundle matches the host policy, then instantiates the WASM module.",
      "type": "object",
      "required": [
        "capabilities",
        "id",
        "signature"
      ],
      "properties": {
        "capabilities": {
          "description": "Capability declaration — must fit within the host's policy.",
          "allOf": [
            {
              "$ref": "#/definitions/CapabilityDeclaration"
            }
          ]
        },
        "display_name": {
          "description": "Human-friendly label.",
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "signature": {
          "description": "Signature over `wasm` bytes (see [`ScriptSignature`]).",
          "allOf": [
            {
              "$ref": "#/definitions/ScriptSignature"
            }
          ]
        },
        "source_cid": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_inline_base64": {
          "description": "Optional DSL source (inline base64) or a reference to a content-addressed blob holding the source.",
          "type": [
            "string",
            "null"
          ]
        },
        "tags": {
          "description": "Free-form tags.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "wasm_cid": {
          "type": [
            "string",
            "null"
          ]
        },
        "wasm_inline_base64": {
          "description": "Compiled WASM — same inline-vs-cid split as the source.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "ScriptSignature": {
      "description": "Ed25519-style signature record. The cryptographic verification is performed by `aether-security`; this schema layer merely ensures the record is structurally well-formed.",
      "type": "object",
      "required": [
        "key_id",
        "public_key_base64",
        "signature_base64"
      ],
      "properties": {
        "algorithm": {
          "description": "Algorithm identifier, e.g., \"ed25519\".",
          "default": "ed25519",
          "type": "string"
        },
        "key_id": {
          "description": "Identifier of the signing key (human-friendly).",
          "type": "string"
        },
        "public_key_base64": {
          "description": "Base64-encoded public key.",
          "type": "string"
        },
        "signature_base64": {
          "description": "Base64-encoded signature over the canonical bytes of the WASM module.",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "SpawnPoint": {
      "description": "Spawn point. Mirrors `aether_world_runtime::SpawnPoint`.",
      "type": "object",
      "required": [
        "id",
        "position"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "is_default": {
          "default": false,
          "type": "boolean"
        },
        "position": {
          "type": "array",
          "items": {
            "type": "number",
            "format": "float"
          },
          "maxItems": 3,
          "minItems": 3
        },
        "yaw_deg": {
          "default": 0.0,
          "type": "number",
          "format": "float"
        }
      },
      "additionalProperties": false
    },
    "Transform": {
      "description": "Rigid-body transform in world space.",
      "type": "object",
      "required": [
        "position",
        "rotation_euler_deg"
      ],
      "properties": {
        "position": {
          "type": "array",
          "items": {
            "type": "number",
            "format": "float"
          },
          "maxItems": 3,
          "minItems": 3
        },
        "rotation_euler_deg": {
          "type": "array",
          "items": {
            "type": "number",
            "format": "float"
          },
          "maxItems": 3,
          "minItems": 3
        },
        "scale": {
          "default": [
            1.0,
            1.0,
            1.0
          ],
          "type": "array",
          "items": {
            "type": "number",
            "format": "float"
          },
          "maxItems": 3,
          "minItems": 3
        }
      },
      "additionalProperties": false
    },
    "WorldManifestMeta": {
      "description": "Informational manifest metadata.",
      "type": "object",
      "properties": {
        "author": {
          "type": [
            "string",
            "null"
          ]
        },
        "created_at_unix": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}